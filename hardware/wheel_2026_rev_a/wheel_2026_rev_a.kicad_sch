	(text "BOURNS 3314 potentiometers move \nwiper to 3 when turned clockwise"
		(exclude_from_sim no)
		(at 148.59 86.36 0)
		(effects
			(font
				(size 1.27 1.27)
				(italic yes)
			)
		)
		(uuid "dd995261-0ba8-4f3c-a846-1fb14e7549b9")
	)
	(text_box "Two stage op-amp circuit. The threshold voltage is buffered to prevent loading effects from the hysteresis division that follows. Hysteresis is used to prevent spurrious switching near the threshold.\n\nFirst set the threshold, by setting the hysteresis potentiometer to entirely favour the threshold value (short between pins 2 and 3 on RV1) before probing TP3 and adjusting the threshold with RV2 - it should be about halfway through the reflectivity signal's range as the wheel rotates past it.\n\nOnce the threshold is set, adjust RV1 to introduce the desired level of hysteresis."
		(exclude_from_sim no)
		(at 22.86 89.535 0)
		(size 66.04 30.5285)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width -0.0001)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "5c6f666e-a9d7-423f-8638-26bbe81c03c3")
	)
	(text_box "Known issue is that the IR sensor gets saturated and fails when the brakes get hot and thus fails to detect the spokes' absence."
		(exclude_from_sim no)
		(at 73.66 152.4 0)
		(size 66.04 6.35)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
